{
  "name": "@agentskit/os-observability-otel",
  "version": "0.0.0",
  "description": "OpenTelemetry binding for @agentskit/os-observability — span exporter, log writer, metric sink adapters.",
  "keywords": ["agentskit", "agentskit-os", "observability", "opentelemetry", "otel"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@agentskit/os-core": "workspace:^",
    "@agentskit/os-observability": "workspace:^",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@agentskit/os-core": "workspace:*",
    "@agentskit/os-observability": "workspace:*",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.4.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskitos": {
    "distribution": "public",
    "stability": "alpha",
    "stabilityNote": "Pre-1.0 M1 alpha. Structural-typed against OTel SDK shape; no hard dep until OTel API stabilizes around the binding."
  },
  "license": "MIT",
  "homepage": "https://github.com/AgentsKit-io/agentskit-os/tree/main/packages/os-observability-otel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit-os.git",
    "directory": "packages/os-observability-otel"
  },
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit-os/issues"
  },
  "author": "AgentsKit Contributors"
}
