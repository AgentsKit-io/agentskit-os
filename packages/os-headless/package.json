{
  "name": "@agentskit/os-headless",
  "version": "0.0.0",
  "description": "AgentsKitOS headless runner — first-class bridge between a workspace config and a running agent without any UI.",
  "keywords": ["agentskit", "agentskit-os", "headless", "runner", "flow"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@agentskit/os-core": "workspace:^",
    "@agentskit/os-flow": "workspace:^",
    "@agentskit/os-runtime": "workspace:^",
    "@agentskit/os-storage": "workspace:^",
    "@agentskit/os-audit": "workspace:^",
    "@agentskit/os-sandbox": "workspace:^",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@agentskit/os-core": "workspace:*",
    "@agentskit/os-flow": "workspace:*",
    "@agentskit/os-runtime": "workspace:*",
    "@agentskit/os-storage": "workspace:*",
    "@agentskit/os-audit": "workspace:*",
    "@agentskit/os-sandbox": "workspace:*",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.4.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskitos": {
    "distribution": "public",
    "stability": "alpha",
    "stabilityNote": "Pre-1.0. M1 alpha — initial release. API may change before 1.0."
  },
  "license": "MIT",
  "homepage": "https://github.com/AgentsKit-io/agentskit-os/tree/main/packages/os-headless",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit-os.git",
    "directory": "packages/os-headless"
  },
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit-os/issues"
  },
  "author": "AgentsKit Contributors"
}
