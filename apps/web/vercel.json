{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @agentskit/web build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": ".next",
  "ignoreCommand": "npx -y turbo-ignore @agentskit/web --fallback=HEAD^1",
  "git": { "deploymentEnabled": { "main": true } },
  "github": { "silent": true }
}
