{
  "name": "@agentskit/os-observability",
  "version": "1.0.0-alpha.1",
  "description": "AgentsKitOS observability — pure decision logic converting OS events into structured logs / traces / metrics. Pluggable sinks.",
  "keywords": [
    "agentskit",
    "agentskit-os",
    "observability",
    "telemetry",
    "logs",
    "traces",
    "metrics"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./coding-task-report": {
      "types": "./dist/coding-task-report-exports.d.ts",
      "import": "./dist/coding-task-report-exports.js",
      "require": "./dist/coding-task-report-exports.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --filter @agentskit/os-dev-orchestrator build && tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@agentskit/os-core": "workspace:^",
    "@agentskit/os-dev-orchestrator": "workspace:^",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@agentskit/os-dev-orchestrator": {
      "optional": true
    }
  },
  "devDependencies": {
    "@agentskit/os-audit": "workspace:*",
    "@agentskit/os-core": "workspace:*",
    "@agentskit/os-dev-orchestrator": "workspace:*",
    "@agentskit/os-flow": "workspace:*",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.4.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskitos": {
    "distribution": "public",
    "stability": "alpha",
    "stabilityNote": "Pre-1.0 M1 alpha — log sink only; trace + metric sinks land in subsequent PRs (ADR-0016)."
  },
  "license": "MIT",
  "homepage": "https://github.com/AgentsKit-io/agentskit-os/tree/main/packages/os-observability",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit-os.git",
    "directory": "packages/os-observability"
  },
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit-os/issues"
  },
  "author": "AgentsKit Contributors"
}
