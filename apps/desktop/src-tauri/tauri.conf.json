{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentsKitOS",
  "identifier": "dev.agentskit.os",
  "version": "0.0.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:web"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "AgentsKitOS",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "theme": "Dark",
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    },
    "macOSPrivateApi": true,
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "AgentsKit Contributors",
    "category": "DeveloperTool",
    "shortDescription": "OS-layer for the agent era",
    "longDescription": "AgentsKitOS desktop shell — visual harness for running, monitoring and debugging AI agents."
  }
}
