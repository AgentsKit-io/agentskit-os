{
  "name": "@agentskit/os-core",
  "version": "0.0.0",
  "description": "Pure foundation for AgentsKitOS — contracts, event bus, workspace model, config schema. Zero runtime deps.",
  "keywords": [
    "agentskit",
    "agentskit-os",
    "agents",
    "orchestration",
    "contracts",
    "zod",
    "typescript",
    "zero-dependencies"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema/workspace": {
      "types": "./dist/schema/workspace.d.ts",
      "import": "./dist/schema/workspace.js",
      "require": "./dist/schema/workspace.cjs"
    },
    "./schema/agent": {
      "types": "./dist/schema/agent.d.ts",
      "import": "./dist/schema/agent.js",
      "require": "./dist/schema/agent.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.4.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskitos": {
    "stability": "alpha",
    "stabilityNote": "Pre-1.0. Contracts landing across M1.",
    "sizeBudgetGzipped": "15KB"
  },
  "license": "MIT",
  "homepage": "https://github.com/AgentsKit-io/agentskit-os/tree/main/packages/os-core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit-os.git",
    "directory": "packages/os-core"
  },
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit-os/issues"
  },
  "author": "AgentsKit Contributors"
}
