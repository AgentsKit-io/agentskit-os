{
  "name": "@agentskit/desktop",
  "version": "0.0.1-alpha.0",
  "private": true,
  "description": "AgentsKitOS desktop shell — Tauri 2 + React 19 + Tailwind + shadcn.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vite": "vite --host 127.0.0.1 --port 5173",
    "build": "vite build && tauri build",
    "build:web": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agentskit/os-core": "workspace:*",
    "@agentskit/os-desktop": "workspace:*",
    "@agentskit/os-headless": "workspace:*",
    "@agentskit/os-observability": "workspace:*",
    "@agentskit/os-ui": "workspace:^",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "driver.js": "^1.4.0",
    "lucide-react": "^0.513.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.5"
  },
  "agentskitos": {
    "distribution": "bundled-private"
  }
