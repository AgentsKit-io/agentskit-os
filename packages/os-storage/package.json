{
  "name": "@agentskit/os-storage",
  "version": "1.0.0-alpha.0",
  "description": "AgentsKitOS storage adapters — file-backed CheckpointStore + lockfile reader/writer.",
  "keywords": [
    "agentskit",
    "agentskit-os",
    "storage",
    "checkpoint",
    "durable"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "yaml": "^2.6.1"
  },
  "peerDependencies": {
    "@agentskit/os-core": "workspace:^",
    "@agentskit/os-flow": "workspace:^",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@agentskit/os-core": "workspace:*",
    "@agentskit/os-flow": "workspace:*",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.4.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskitos": {
    "distribution": "public",
    "stability": "alpha",
    "stabilityNote": "Pre-1.0. M1 alpha — file-backed storage."
  },
  "license": "MIT",
  "homepage": "https://github.com/AgentsKit-io/agentskit-os/tree/main/packages/os-storage",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit-os.git",
    "directory": "packages/os-storage"
  },
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit-os/issues"
  },
  "author": "AgentsKit Contributors"
}
