{
  "name": "@agentskit/os-desktop",
  "version": "0.0.1-alpha.0",
  "private": true,
  "description": "AgentsKitOS desktop React application — bundled-private package consumed by apps/desktop (Tauri shell). Per ADR-0018 §3.5 + ADR-0014.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./globals.css": "./src/globals.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agentskit/os-core": "workspace:*",
    "@agentskit/os-headless": "workspace:*",
    "@agentskit/os-observability": "workspace:*",
    "@agentskit/os-ui": "workspace:^",
    "driver.js": "^1.4.0",
    "lucide-react": "^0.513.0"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^26.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.6.3",
    "zod": "^4.4.2",
    "vitest": "^4.1.5"
  },
  "agentskitos": {
    "distribution": "bundled-private"
  }
}
